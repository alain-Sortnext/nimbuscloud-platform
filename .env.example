# NimbusCloud Platform — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# AWS Configuration
AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Application Environment
ENVIRONMENT=development
APP_VERSION=2.4.1

# Database
DYNAMODB_TABLE=nimbuscloud-sessions
DYNAMODB_ENDPOINT=

# S3
S3_BUCKET=nimbuscloud-platform-assets
S3_REGION=eu-west-2

# Auth Service
JWT_SECRET=
JWT_EXPIRY=3600
# DB_PASSWORD should come from Secrets Manager — do NOT set here in production

# Payment API
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_TIMEOUT_MS=5000

# Notification Service
SQS_QUEUE_URL=
SES_FROM_ADDRESS=noreply@nimbuscloud.io

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=

# Docker / Container Registry
ECR_REGISTRY=
DOCKER_IMAGE_TAG=latest

